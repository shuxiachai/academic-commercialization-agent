# Copy this file to .env and fill in your own keys.
# .env is gitignored and will never be committed.

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Auto-detected from whichever API key is present (DeepSeek → Anthropic → OpenAI).
# Set LLM_PROVIDER explicitly to override:
#   LLM_PROVIDER=deepseek   (default model: deepseek-chat)
#   LLM_PROVIDER=anthropic  (default model: claude-sonnet-5)
#   LLM_PROVIDER=openai     (default model: gpt-4o)
# LLM_PROVIDER=deepseek

# ── Option A: DeepSeek ────────────────────────────────────────────────────────
# Sign up at https://platform.deepseek.com/api-keys
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# DEEPSEEK_MODEL=deepseek-chat         # optional; default: deepseek-chat
# DEEPSEEK_API_BASE=https://api.deepseek.com  # optional; change for local proxy

# ── Option B: Anthropic Claude ────────────────────────────────────────────────
# Sign up at https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-5      # optional; default: claude-sonnet-5

# ── Option C: OpenAI ──────────────────────────────────────────────────────────
# Sign up at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_MODEL=gpt-4o                  # optional; default: gpt-4o
# OPENAI_API_BASE=https://...          # optional; set for Azure or local proxy

# ── Serper API (required for patent & market search) ──────────────────────────
# Sign up at https://serper.dev/api-key  (free tier: 2 500 queries/month)
SERPER_API_KEY=your-serper-key-here

# ── Optional: Semantic Scholar API Key ────────────────────────────────────────
# Raises rate limit from 1 req/s to 10 req/s. System works without it.
# Apply at https://www.semanticscholar.org/product/api
# SEMANTIC_SCHOLAR_API_KEY=your-s2-key-here

# ── Optional: Lens.org Patent API Key (free after registration) ───────────────
# Enables structured patent search via Lens.org (>120M global patents).
# Without this key the system falls back to Serper for patent search.
# Sign up (free) at https://www.lens.org/lens/user/subscriptions
# LENS_API_KEY=your-lens-key-here

# ── Optional: NCBI API Key (free) ─────────────────────────────────────────────
# Raises PubMed E-utilities rate limit from 3 to 10 req/s.
# Apply at https://www.ncbi.nlm.nih.gov/account/
# NCBI_API_KEY=your-ncbi-key-here

# ── Optional: API rate limit ──────────────────────────────────────────────────
# Default 6 req/min suits DeepSeek free tier. Raise for OpenAI/Anthropic.
# MAX_RPM=20

# ── Legacy variable names (still accepted as fallbacks) ───────────────────────
# OPENAI_API_KEY / OPENAI_API_BASE / OPENAI_MODEL_NAME all map to DeepSeek
# when LLM_PROVIDER=deepseek, for backward compatibility with older setups.
