# Copy this file to .env and fill in your own keys.
# .env is gitignored and will never be committed.

# ── DeepSeek API ──────────────────────────────────────────────────────────────
# Sign up at https://platform.deepseek.com/api-keys
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Serper API ────────────────────────────────────────────────────────────────
# Sign up at https://serper.dev/api-key  (free tier: 2 500 queries/month)
SERPER_API_KEY=your-serper-key-here

# ── Optional: Semantic Scholar API Key ────────────────────────────────────────
# Raises rate limit from 1 req/s to 10 req/s. System works without it.
# Apply at https://www.semanticscholar.org/product/api
# SEMANTIC_SCHOLAR_API_KEY=your-s2-key-here

# ── Legacy / OpenAI-compatible variable names (also accepted) ─────────────────
# If you prefer the OpenAI-style naming, these work as fallbacks:
# OPENAI_API_KEY=sk-your-deepseek-key-here
# OPENAI_API_BASE=https://api.deepseek.com
# OPENAI_MODEL_NAME=deepseek-chat
